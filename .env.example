# ── Helios Environment Variables Template ─────────────────────────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── LLM ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_strong_random_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# ── PostgreSQL (local / EC2) ──────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=helios
POSTGRES_USER=helios
POSTGRES_PASSWORD=your_postgres_password_here
DATABASE_URL=postgresql+asyncpg://helios:your_postgres_password_here@postgres:5432/helios

# ── Supabase (managed PostgreSQL — replaces local postgres in production) ─────
# Format: postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@HOST:5432/postgres
# Leave empty to use local PostgreSQL instead.
SUPABASE_DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── MinIO Object Storage ──────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=helios-docs
MINIO_SECURE=false

# ── ChromaDB Vector Store ─────────────────────────────────────────────────────
CHROMA_HOST=chroma
CHROMA_PORT=8001
CHROMA_COLLECTION=helios

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development         # development | production
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Security ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
TRUSTED_PROXY_COUNT=0
MAX_UPLOAD_BYTES=52428800

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=helios

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_USER=60
RATE_LIMIT_WINDOW_SECONDS=60
GUEST_QUERY_LIMIT=1

# ── Agent Tuning ──────────────────────────────────────────────────────────────
RETRIEVER_TOP_K=10
RETRIEVER_DENSE_WEIGHT=0.6
RETRIEVER_BM25_WEIGHT=0.1
CRITIC_MIN_SCORE=0.7
