# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=helios
POSTGRES_USER=helios
POSTGRES_PASSWORD=helios_pass
DATABASE_URL=postgresql+asyncpg://helios:helios_pass@localhost:5432/helios

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=helios-docs
MINIO_SECURE=false

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=helios

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=helios

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Agent Tuning ──────────────────────────────────────────────────────────────
PLANNER_MAX_SUBTASKS=5
RETRIEVER_TOP_K=10
RETRIEVER_DENSE_WEIGHT=0.6
RETRIEVER_CLIP_WEIGHT=0.3
RETRIEVER_BM25_WEIGHT=0.1
EXECUTOR_TIMEOUT_SECONDS=15
CRITIC_MIN_SCORE=0.7
