# URL of the deployed Helios backend (no trailing slash)
# Set this as a GitHub Actions secret named VITE_API_URL
VITE_API_URL=https://your-helios-api.onrender.com

# Base path for the app — /helios when hosted at github.com/hridambiswas/helios
# Leave as / for local dev or Vercel (handled automatically by the workflow)
VITE_BASE_PATH=/helios
