# ── LLM (Groq — free tier) ────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=helios
POSTGRES_USER=helios
POSTGRES_PASSWORD=your-postgres-password
DATABASE_URL=postgresql+asyncpg://helios:your-postgres-password@localhost:5432/helios

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-user
MINIO_SECRET_KEY=your-minio-password
MINIO_BUCKET=helios-docs
MINIO_SECURE=false

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=helios

# ── CORS (comma-separated or JSON array) ─────────────────────────────────────
CORS_ALLOWED_ORIGINS=["https://your-frontend.vercel.app","http://localhost:5173"]

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Agent Tuning ──────────────────────────────────────────────────────────────
PLANNER_MAX_SUBTASKS=5
RETRIEVER_TOP_K=10
RETRIEVER_DENSE_WEIGHT=0.6
RETRIEVER_CLIP_WEIGHT=0.3
RETRIEVER_BM25_WEIGHT=0.1
EXECUTOR_TIMEOUT_SECONDS=15
CRITIC_MIN_SCORE=0.7
