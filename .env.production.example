# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=production

# ── LLM (Groq) ───────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://helios:STRONG_PASSWORD@postgres:5432/helios
POSTGRES_PASSWORD=STRONG_PASSWORD_HERE

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=chroma
CHROMA_PORT=8000

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=YOUR_MINIO_USER
MINIO_SECRET_KEY=YOUR_STRONG_MINIO_PASSWORD
MINIO_BUCKET=helios-docs

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=GENERATE_WITH_OPENSSL_RAND_HEX_32

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL
CORS_ALLOWED_ORIGINS=https://your-project.vercel.app
