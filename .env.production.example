# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://helios:helios_pass@postgres:5432/helios

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=chroma
CHROMA_PORT=8000

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin          # CHANGE THIS
MINIO_BUCKET=helios-docs

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL
CORS_ALLOWED_ORIGINS=https://frontend-omega-blush-87.vercel.app
